generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model VibeToken {
  id                String    @id
  trackId           String
  trackTitle        String
  trackArtist       String
  albumName         String
  albumArt          String
  previewUrl        String?
  spotifyId         String
  mode              String    // AUTO | PICK
  startSec          Int?
  senderDisplayName String
  senderId          String?
  senderIp          String?
  senderCity        String?
  senderCountry     String?
  receiverId        String?
  receiverIp        String?
  receiverCity      String?
  receiverCountry   String?
  createdAt         DateTime  @default(now())
  expiresAt         DateTime
  playedAt          DateTime?
  reaction          String?   // VIBE | NOPE
  reactedAt         DateTime?
  revealedAt        DateTime?
  gameMode          String    @default("vibe") // vibe | guess
  decoyArtists      String?   // JSON array of 3 decoy artist names

  @@index([expiresAt])
  @@index([senderId])
  @@index([receiverId])
}

model Streak {
  id            String   @id @default(uuid())
  userAId       String
  userBId       String
  streakCount   Int      @default(1)
  lastVibeDate  DateTime @default(now())

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model Session {
  id                  String   @id
  spotifyAccessToken  String
  spotifyRefreshToken String
  spotifyUserId       String
  displayName         String
  tokenExpiresAt      DateTime
  expiresAt           DateTime
  createdAt           DateTime @default(now())

  @@index([expiresAt])
}
